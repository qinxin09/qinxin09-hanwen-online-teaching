<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
    <!-- 数据库驱动:选择你的本地硬盘上面的数据库驱动包 -->
    <classPathEntry location="E:\mavenSoft\mysql\mysql-connector-java\8.0.15\mysql-connector-java-8.0.15.jar"/>
    <!-- 此处ID和数据库连接处名称一致 -->
    <context id="hanwenonline" targetRuntime="MyBatis3">
        <commentGenerator>
            <property name="suppressDate" value="true" />
            <!-- 是否去除自动生成的注释 true：是 ： false:否 -->
            <property name="suppressAllComments" value="true" />
        </commentGenerator>
        <jdbcConnection
                driverClass="com.mysql.cj.jdbc.Driver"         connectionURL="jdbc:mysql://localhost:3306/hanwenonline?useUnicode=true&amp;characterEncoding=utf8&amp;serverTimezone=GMT%2B8&amp;useSSL=false"
                userId="root" password="123456">
            <!-- 如果你不是标准的数据库表命名格式，就有可能出现数据库中的所有同名表被多次生成的情况；
            解决mysql8.0以后重复生成所有表的问题-->
            <property name="nullCatalogMeansCurrent" value="true" />
        </jdbcConnection>
        <javaTypeResolver>
            <property name="forceBigDecimals" value="false" />
        </javaTypeResolver>
        <javaModelGenerator     targetPackage="com.yws.onlinestudymanage.pojo" targetProject="src/main/java">
            <property name="enableSubPackages" value="true" />
            <property name="trimStrings" value="true" />
        </javaModelGenerator>
<!--        <sqlMapGenerator targetPackage="com.yws.onlinestudymanage.mapper"-->
            <sqlMapGenerator targetPackage="mapper"
                         targetProject="src/main/resources">
            <property name="enableSubPackages" value="true" />
        </sqlMapGenerator>
        <javaClientGenerator type="XMLMAPPER"
                             targetPackage="com.yws.onlinestudymanage.dao" targetProject="src/main/java">
            <property name="enableSubPackages" value="true" />
        </javaClientGenerator>
<!--        <table tableName="course" domainObjectName="Course"-->
<!--               enableCountByExample="true" enableUpdateByExample="true"-->
<!--               enableDeleteByExample="true" enableSelectByExample="true"-->
<!--               selectByExampleQueryId="true"></table>-->
<!--        <table tableName="classroom" domainObjectName="ClassRoom"-->
<!--               enableCountByExample="true" enableUpdateByExample="true"-->
<!--               enableDeleteByExample="true" enableSelectByExample="true"-->
<!--               selectByExampleQueryId="true"></table>-->
        <table tableName="study_record" domainObjectName="StudyRecord"
               enableCountByExample="true" enableUpdateByExample="true"
               enableDeleteByExample="true" enableSelectByExample="true"
               selectByExampleQueryId="true"></table>
<!--        <table tableName="notice" domainObjectName="Notice"-->
<!--               enableCountByExample="true" enableUpdateByExample="true"-->
<!--               enableDeleteByExample="true" enableSelectByExample="true"-->
<!--               selectByExampleQueryId="true"></table>-->
    </context>

</generatorConfiguration>
